{
  "expo": {
    "name": "Cabuk Driver",
    "slug": "cabuk-driver-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-location"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joel.cabukdriver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used for driver navigation and delivery guidance in Albania.",
        "NSCameraUsageDescription": "Camera access is used to take your profile photo.",
        "NSPhotoLibraryUsageDescription": "Photo library access is used to select your profile photo.",
        "NSPhotoLibraryAddUsageDescription": "Photo library access is used to save your profile photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF7F1"
      },
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.joel.cabukdriver"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "73926714-0531-4336-803d-8862aa59ebc0"
      }
    }
  }
}
